# ============================================
# Hidden files / folders (except .gitignore)
# ============================================
.*
!.gitignore
!.gitattributes

# ============================================
# Office Documents (Excel, PowerPoint)
# ============================================
*.xlsx
*.xls
*.xlsm
*.xlsb
*.pptx
*.ppt
*.ppsx

# ============================================
# Python
# ============================================
.venv/
.venv_temp/
__pycache__/
*.pyc
*.py[cod]
*$py.class

# ============================================
# Node.js
# ============================================
node_modules/

# ============================================
# Database Files (local only)
# ============================================
data/chroma_db/
*.db
*.sqlite

# ============================================
# Debug & Temporary Files
# ============================================
*.html
debug_local_html.py
test_*.py
test_*.html
*.tmp
*.temp

# ============================================
# OS Generated Files
# ============================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================
# IDE / Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
